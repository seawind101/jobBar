<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user && user.username ? user.username + "'s Profile" : 'Profile' %></title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>
        <div id="parentCont">
            <div id="topInf">
                <h1><%= user && user.username ? user.username : 'User' %>'s Profile</h1>

                <section>
                    <div id="fid">
                        <img src="/icons/fid.png" width="25" height="25"> 
                        <strong><%= user.fb_id %></strong>
                    </div>
                </section>
            </div>
            <div id="info">
                <section id="companiesSec">
                    <div class="title">Owned Companies</div>
                    <% if (companies && companies.length > 0) { %>
                        <ul>
                        <% companies.forEach(c => { %>
                            <li class="accComp">
                                <div class="compTtl"><strong><%= c.name.length > 30 ? c.name.substring(0, 30) + '...' : c.name %></strong></div>
                                <div class="compBtnsCont">
                                    <div class="btn">
                                        <a id="viewCompany" href="/job/<%= encodeURIComponent(c.name) %>">
                                            <img src="/icons/view.png" width="25" height="25">
                                        </a>
                                        <div class="tooltip">View Company</div>
                                    </div>
                                    <div class="btn">
                                        <a id="editCompany" href="/edit/company/<%= c.id %>">
                                            <img src="/icons/edit.png" width="25" height="25">
                                        </a>
                                        <div class="tooltip" id="edit">Edit Company</div>
                                    </div>
                                </div>
                            </li>
                            <% if (companies.indexOf(c) < companies.length - 1) { %><hr><% } %>
                        <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">You do not own any companies yet</p>
                    <% } %>
                </section>

                <section id="posSec">
                    <div class="title">Positions Applied To</div>
                    <% if (positionsApplied && positionsApplied.length > 0) { %>
                        <ul>
                            <% positionsApplied.forEach(p => { %>
                                <li class="accPos">
                                    <div class="posTtl">
                                        <strong><%= p.title.length > 30 ? p.title.substring(0, 30) + '...' : p.title %></strong>
                                        <a href="/job/<%= encodeURIComponent(p.company_name) %>"><%= p.company_name %></a>
                                    </div>
                                </li>
                                <% if (positionsApplied.indexOf(p) < positionsApplied.length - 1) { %><hr><% } %>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">No position applications found</p>
                    <% } %>
                </section>

                <section id="issuesSec">
                    <div class="title">Issues</div>
                    <% if ((jobsApplied && jobsApplied.length > 0) || (jobsAccepted && jobsAccepted.length > 0)) { %>
                        <ul>
                            <% if (jobsApplied && jobsApplied.length > 0) { %>
                                <% jobsApplied.forEach((j, index) => { %>
                                    <li class="accIssues" style="position:relative;" data-job-id="<%= j.id %>">
                                        <div class="issTtl"><strong class="issue-title"><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                        <div class="status <%= j.status %>"><% if (j.status === 'available') { %> applied <% } %></div>

                                        <div class="issue-popup" aria-hidden="true">
                                            <div class="popup-title"><%= j.title %></div>
                                            <div class="popup-desc"><%= j.description %></div>
                                            <% if (j.link) { %>
                                                <div class="popup-link">Link: <a href="<%= j.link %>" target="_blank" rel="noopener noreferrer"><%= j.link %></a></div>
                                            <% } %>
                                            <div class="popup-pay">Pay: <%= typeof j.pay !== 'undefined' && j.pay !== null ? j.pay : 'N/A' %></div>
                                        </div>
                                    </li>
                                    <% if (index < jobsApplied.length - 1 || (jobsAccepted && jobsAccepted.length > 0)) { %><hr><% } %>
                                <% }) %>
                            <% } %>

                            <% if (jobsAccepted && jobsAccepted.length > 0) { %>
                                <% jobsAccepted.forEach((j, index) => { %>
                                    <li class="accIssues" style="position:relative;" data-job-id="<%= j.id %>">
                                        <div class="issTtl"><strong class="issue-title"><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                        <div class="status <%= j.status %>"><% if (j.status === 'in_progress') { %> in progress <% } else { %><%= j.status %><% } %></div>

                                        <div class="issue-popup" aria-hidden="true">
                                            <div class="popup-title"><%= j.title %></div>
                                            <div class="popup-desc"><%= j.description %></div>
                                            <% if (j.link) { %>
                                                <div class="popup-link">Link: <a href="<%= j.link %>" target="_blank" rel="noopener noreferrer"><%= j.link %></a></div>
                                            <% } %>
                                            <div class="popup-pay">Pay: <%= typeof j.pay !== 'undefined' && j.pay !== null ? j.pay : 'N/A' %></div>
                                        </div>
                                    </li>
                                    <% if (index < jobsAccepted.length - 1) { %><hr><% } %>
                                <% }) %>
                            <% } %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">No issues found</p>
                    <% } %>
                </section>
            <section id="empSec">
                <div class="title">Employment Status</div>
                <% if (positionsAccepted && positionsAccepted.length > 0) { %>
                    <ul>
                        <% positionsAccepted.forEach(p => { %>
                            <li class="empPos">
                                <div class="empTtl">
                                    <strong><%= p.title %></strong>
                                    <a href="/job/<%= encodeURIComponent(p.company_name) %>"><%= p.company_name || 'Company' %></a>
                                </div>
                                <div class="empActions">
                                    <form action="/profile/quit-position" method="POST" onsubmit="return confirm('Are you sure you want to quit this position?');">
                                        <input type="hidden" name="positionId" value="<%= p.id %>">
                                        <div class="btn">
                                            <button type="submit" class="quit-btn">
                                                <img src="/icons/quit.png" width="25" height="25">
                                            </button>
                                            <div class="tooltip" id="quit">Resign</div>
                                        </div>
                                    </form>
                                </div>
                            </li>
                            <% if (positionsAccepted.indexOf(p) < positionsAccepted.length - 1) { %><hr><% } %>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="emptyTxt">You are not a fulltime employee for any company</p>
                <% } %>
            </section>
            </div>
        </div>
    <style>
                /* Popup to the left of the issue item */
        #issuesSec .accIssues { position: relative; }
        #issuesSec .accIssues .issue-popup {
            position: absolute;
            right: 100%;
            top: 0;
            margin-right: 12px;
            min-width: 280px;
            max-width: 460px;
            background: #fff;
            color: #000;
            padding: 12px;
            border-radius: 8px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.22);
            display: none;
            z-index: 1200;
        }
        /* show on hover */
        #issuesSec .accIssues:hover .issue-popup { display: block; }

        /* On small screens, show below instead of left */
        @media (max-width: 700px) {
            #issuesSec .accIssues .issue-popup { right: auto; left: 0; top: 100%; margin-right: 0; margin-top: 8px; }
        }

            /* Allow popup to overflow the section container and the inner list */
            #info #issuesSec { overflow: visible; }
            /* the UL inside the issues section is scrollable by default; allow popups to escape it */
            #info #issuesSec ul { overflow: visible; }

        .issue-popup .popup-title { font-weight: 700; margin-bottom: 6px; }
        .issue-popup .popup-desc { margin-bottom: 8px; white-space: pre-wrap; }
        .issue-popup .popup-link a { color: #0077cc; word-break: break-all; }
        .issue-popup .popup-pay { margin-top: 6px; font-weight: 600; }
                /* ensure locked popup remains visible */
                #issuesSec .accIssues.locked .issue-popup { display: block; }
    </style>

    <script>
        // Click the issue title to lock/unlock the left popup so links can be clicked.
        document.addEventListener('DOMContentLoaded', function(){
            const items = document.querySelectorAll('#issuesSec .accIssues');
            items.forEach(li => {
                const title = li.querySelector('.issue-title');
                if (!title) return;

                title.style.cursor = 'pointer';
                title.addEventListener('click', function(ev){
                    ev.preventDefault();
                    const locked = li.classList.toggle('locked');
                    const popup = li.querySelector('.issue-popup');
                    if (popup) popup.setAttribute('aria-hidden', locked ? 'false' : 'true');

                    if (locked) {
                        // close when clicking outside
                        const handleOutside = function(e){
                            if (!li.contains(e.target)) {
                                li.classList.remove('locked');
                                if (popup) popup.setAttribute('aria-hidden', 'true');
                                document.removeEventListener('click', handleOutside);
                            }
                        };
                        setTimeout(() => document.addEventListener('click', handleOutside), 0);
                    }
                });
            });
        });
    </script>

</body>
</html>