<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user && user.username ? user.username + "'s Profile" : 'Profile' %></title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>
        <div id="parentCont">
            <div>
                <h1><%= user && user.username ? user.username : 'User' %>'s Profile</h1>

                <section>
                    <p><strong>FB ID:</strong> <%= user.fb_id %></p>
                    <% if (user.email) { %><p><strong>Email:</strong> <%= user.email %></p><% } %>
                </section>
            </div>
            <div id="info">
                <section>
                    <div class="title">Companies You Own</div>
                    <% if (companies && companies.length > 0) { %>
                        <ul>
                        <% companies.forEach(c => { %>
                            <li>
                                <strong><%= c.name %></strong> — <a href="/job/<%= encodeURIComponent(c.name) %>">View Jobs</a>
                                <a href="/edit/company/<%= c.id %>">Edit</a>
                            </li>
                        <% }) %>
                        </ul>
                    <% } else { %>
                        <p>You do not own any companies yet.</p>
                    <% } %>
                </section>

                <section>
                    <div class="title">Positions You Applied To</div>
                    <% if (positionsApplied && positionsApplied.length > 0) { %>
                        <ul>
                            <% positionsApplied.forEach(p => { %>
                                <li><strong><%= p.title %></strong> — <a href="/eJob/<%= encodeURIComponent(p.company_name || '') %>">View Position</a> at <em><%= p.company_name || 'Company' %></em></li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p>No position applications found.</p>
                    <% } %>
                </section>

                <section id="issuesSec">
                    <div class="title">Issues</div>
                    <% if (jobsAccepted && jobsAccepted.length > 0 && jobsApplied && jobsApplied.length > 0) { %>
                        <ul>
                            <% jobsApplied.forEach((j, index) => { %>
                                <li class="accIssues">
                                    <div class="issTtl"><strong><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                    <div class="status <%= j.status %>"><% if (j.status === 'in_progress') { %> in progress <% } else { %><%= j.status %><% } %></div>
                                </li>
                                <% if (index < jobsAccepted.length - 1 || index < jobsApplied.length - 1) { %><hr><% } %>
                            <% }) %>
                            <% jobsAccepted.forEach((j, index) => { %>
                                <li class="accIssues">
                                    <div class="issTtl"><strong><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                    <div class="status <%= j.status %>"><% if (j.status === 'in_progress') { %> in progress <% } else { %><%= j.status %><% } %></div>
                                </li>
                                <% if (index < jobsAccepted.length - 1) { %><hr><% } %>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p>Not assigned to any issues.</p>
                    <% } %>
                </section>
            <section>
                <div class="title">Employment Status</div>
                <% if (positionsCompleted && positionsCompleted.length > 0) { %>
                    <ul>
                        <% positionsCompleted.forEach(p => { %>
                            <li><strong><%= p.title %></strong> at <em><%= p.company_name || 'Company' %></em></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>You are not a fulltime employee for any company.</p>
                <% } %>
            </section>
            </div>
        </div>
</body>
</html>