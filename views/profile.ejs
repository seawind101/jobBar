<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user && user.username ? user.username + "'s Profile" : 'Profile' %></title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>
    <%- include("banner.ejs") %>
        <div id="parentCont">
            <div id="topInf">
                <h1><%= user && user.username ? user.username : 'User' %>'s Profile</h1>

                <section>
                    <div id="fid">
                        <img src="/icons/fid.png" width="25" height="25"> 
                        <strong><%= user.fb_id %></strong>
                    </div>
                </section>
            </div>
            <div id="info">
                <section id="companiesSec">
                    <div class="title">Owned Companies</div>
                    <% if (companies && companies.length > 0) { %>
                        <ul>
                        <% companies.forEach(c => { %>
                            <li class="accComp">
                                <div class="compTtl"><strong><%= c.name.length > 30 ? c.name.substring(0, 30) + '...' : c.name %></strong></div>
                                <div class="compBtnsCont">
                                    <div class="btn" id="view">
                                        <a id="viewCompany" href="/job/<%= encodeURIComponent(c.name) %>">
                                            <img src="/icons/view.png" width="25" height="25">
                                        </a>
                                        <div class="tooltip">View Company</div>
                                    </div>
                                    <div class="btn" id="edit">
                                        <a id="editCompany" href="/edit/company/<%= c.id %>">
                                            <img src="/icons/edit.png" width="25" height="25">
                                        </a>
                                        <div class="tooltip" id="edit">Edit Company</div>
                                    </div>
                                    <div class="btn" id="tran">
                                        <button class="transfer-btn" type="button" data-company-id="<%= c.id %>" data-company-name="<%= c.name %>">
                                            <img src="/icons/transfer.png" width="25" height="25">
                                        </button>
                                        <div class="tooltip">Transfer Ownership</div>
                                    </div>
                                </div>
                            </li>
                            <% if (companies.indexOf(c) < companies.length - 1) { %><hr><% } %>
                        <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">You do not own any companies yet</p>
                    <% } %>
                </section>

                <section id="posSec">
                    <div class="title">Positions Applied To</div>
                    <% if (positionsApplied && positionsApplied.length > 0) { %>
                        <ul>
                            <% positionsApplied.forEach(p => { %>
                                <li class="accPos">
                                    <div class="posTtl">
                                        <strong><%= p.title.length > 30 ? p.title.substring(0, 30) + '...' : p.title %></strong>
                                        <a href="/job/<%= encodeURIComponent(p.company_name) %>"><%= p.company_name %></a>
                                    </div>
                                </li>
                                <% if (positionsApplied.indexOf(p) < positionsApplied.length - 1) { %><hr><% } %>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">No position applications found</p>
                    <% } %>
                </section>

                <section id="issuesSec">
                    <div class="title">Contracts</div>
                    <% if ((jobsApplied && jobsApplied.length > 0) || (jobsAccepted && jobsAccepted.length > 0)) { %>
                        <ul>
                            <% if (jobsApplied && jobsApplied.length > 0) { %>
                                <% jobsApplied.forEach((j, index) => { %>
                                    <li class="accIssues" style="position:relative;" data-job-id="<%= j.id %>">
                                        <div class="issTtl"><strong class="issue-title"><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                        <div class="status <%= j.status %>"><% if (j.status === 'available') { %> applied <% } %></div>

                                        <div class="issue-popup" aria-hidden="true">
                                            <div class="popup-title"><%= j.title %></div>
                                            <div class="popup-desc"><%= j.description %></div>
                                            <% if (j.link) { %>
                                                <div class="popup-link">Link: <a href="<%= j.link %>" target="_blank" rel="noopener noreferrer"><%= j.link %></a></div>
                                            <% } %>
                                            <div class="popup-pay">Pay: <%= typeof j.pay !== 'undefined' && j.pay !== null ? j.pay : 'N/A' %></div>
                                        </div>
                                    </li>
                                    <% if (index < jobsApplied.length - 1 || (jobsAccepted && jobsAccepted.length > 0)) { %><hr><% } %>
                                <% }) %>
                            <% } %>

                            <% if (jobsAccepted && jobsAccepted.length > 0) { %>
                                <% jobsAccepted.forEach((j, index) => { %>
                                    <li class="accIssues" style="position:relative;" data-job-id="<%= j.id %>">
                                        <div class="issTtl"><strong class="issue-title"><%= j.title.length > 30 ? j.title.substring(0, 30) + '...' : j.title %></strong><a href="/job/<%= encodeURIComponent(j.company) %>"><%= j.company %></a></div>
                                        <div class="status <%= j.status %>"><% if (j.status === 'in_progress') { %> in progress <% } else { %><%= j.status %><% } %></div>

                                        <div class="issue-popup" aria-hidden="true">
                                            <div class="popup-title"><%= j.title %></div>
                                            <div class="popup-desc"><%= j.description %></div>
                                            <% if (j.link) { %>
                                                <div class="popup-link">Link: <a href="<%= j.link %>" target="_blank" rel="noopener noreferrer"><%= j.link %></a></div>
                                            <% } %>
                                            <div class="popup-pay">Pay: <%= typeof j.pay !== 'undefined' && j.pay !== null ? j.pay : 'N/A' %></div>
                                        </div>
                                    </li>
                                    <% if (index < jobsAccepted.length - 1) { %><hr><% } %>
                                <% }) %>
                            <% } %>
                        </ul>
                    <% } else { %>
                        <p class="emptyTxt">No Contracts found</p>
                    <% } %>
                </section>
            <section id="empSec">
                <div class="title">Employment Status</div>
                <% if (positionsAccepted && positionsAccepted.length > 0) { %>
                    <ul>
                        <% positionsAccepted.forEach(p => { %>
                            <li class="empPos">
                                <div class="empTtl">
                                    <strong><%= p.title %></strong>
                                    <a href="/job/<%= encodeURIComponent(p.company_name) %>"><%= p.company_name || 'Company' %></a>
                                </div>
                                <div class="empActions">
                                    <form action="/profile/quit-position" method="POST" onsubmit="return confirm('Are you sure you want to quit this position?');">
                                        <input type="hidden" name="positionId" value="<%= p.id %>">
                                        <div class="btn">
                                            <button type="submit" class="quit-btn">
                                                <img src="/icons/quit.png" width="25" height="25">
                                            </button>
                                            <div class="tooltip" id="quit">Resign</div>
                                        </div>
                                    </form>
                                </div>
                            </li>
                            <% if (positionsAccepted.indexOf(p) < positionsAccepted.length - 1) { %><hr><% } %>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="emptyTxt">You are not a fulltime employee for any company</p>
                <% } %>
            </section>
            </div>
        </div>
    <style>
        /* hide embedded popups inside list items; we'll render a single floating popup attached to body */
        #issuesSec .issue-popup { display: none; }

        /* floating popup base styles (the element will be appended to body) */
        #floating-issue-popup { position: absolute; display: none; z-index: 9999; min-width: 280px; max-width: 520px; background: #fff; color: #000; padding: 12px; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
        #floating-issue-popup .popup-title { font-weight:700; margin-bottom:6px; }
        #floating-issue-popup .popup-desc { margin-bottom:8px; white-space: pre-wrap; }
        #floating-issue-popup .popup-link a { color: #0077cc; word-break: break-all; }
        #floating-issue-popup .popup-pay { margin-top:6px; font-weight:600; }
    </style>

    <script>
        // Floating popup: attach a single DOM node to body and position it left/right of hovered items.
        document.addEventListener('DOMContentLoaded', function(){
            const popup = document.createElement('div');
            popup.id = 'floating-issue-popup';
            popup.innerHTML = '<div class="popup-inner"></div>';
            document.body.appendChild(popup);

            const popupInner = popup.querySelector('.popup-inner');
            let lockedLi = null;

            function showPopupFor(li){
                const source = li.querySelector('.issue-popup');
                if (!source) return;
                popupInner.innerHTML = source.innerHTML;
                popup.style.display = 'block';
                positionPopup(li);
            }

            function hidePopup(){ if (lockedLi) return; popup.style.display = 'none'; }

            function positionPopup(li){
                const rect = li.getBoundingClientRect();
                // temporarily show to measure
                popup.style.left = '-9999px'; popup.style.top = '-9999px'; popup.style.display = 'block';
                const pw = popup.offsetWidth, ph = popup.offsetHeight;
                let left = rect.left + window.scrollX - pw - 12;
                let top = rect.top + window.scrollY;
                if (left < 8) left = rect.right + window.scrollX + 12;
                const maxTop = window.scrollY + window.innerHeight - ph - 8;
                if (top > maxTop) top = maxTop;
                if (top < window.scrollY + 8) top = window.scrollY + 8;
                popup.style.left = left + 'px'; popup.style.top = top + 'px';
            }

            document.querySelectorAll('#issuesSec .accIssues').forEach(li => {
                li.addEventListener('mouseenter', () => { if (!lockedLi) showPopupFor(li); });
                li.addEventListener('mouseleave', () => { if (!lockedLi) hidePopup(); });
                const title = li.querySelector('.issue-title');
                if (!title) return;
                title.style.cursor = 'pointer';
                title.addEventListener('click', function(ev){
                    ev.preventDefault();
                    if (lockedLi === li) { lockedLi = null; hidePopup(); document.removeEventListener('click', outsideHandler); }
                    else { lockedLi = li; showPopupFor(li); setTimeout(() => document.addEventListener('click', outsideHandler), 0); }
                });
            });

            function outsideHandler(e){
                if (!lockedLi) return;
                if (!lockedLi.contains(e.target) && !popup.contains(e.target)) {
                    lockedLi = null; hidePopup(); document.removeEventListener('click', outsideHandler);
                }
            }

            window.addEventListener('scroll', () => { if (!lockedLi) hidePopup(); });
            window.addEventListener('resize', () => { if (!lockedLi) hidePopup(); });
        });
    </script>

    <!-- Transfer Ownership Modal -->
    <div id="transfer-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); align-items:center; justify-content:center; z-index:10000;">
        <div style="background:#fff; padding:18px; border-radius:8px; width:360px; max-width:92%; box-shadow:0 10px 30px rgba(0,0,0,0.4);">
            <h3 style="margin-top:0;">Transfer Company Ownership</h3>
            <p id="transfer-company-name" style="margin:6px 0 12px 0; font-weight:600;"></p>
            <form id="transfer-form" action="/companies/transfer-owner" method="POST" onsubmit="return confirm('Are you sure you want to transfer ownership of this company?');">
                <input type="hidden" name="companyId" id="transfer-company-id" value="">
                <label for="newOwnerFb">New Owner fb_id</label>
                <input id="newOwnerFb" name="newOwnerFb" type="text" required style="width:100%; padding:8px; margin:8px 0 12px 0;">
                <div style="display:flex; gap:10px; justify-content:flex-end;">
                    <button type="button" id="transfer-cancel" style="padding:8px 12px;">Cancel</button>
                    <button type="submit" style="padding:8px 12px; background:#2a7; color:#fff; border:none; border-radius:4px;">Transfer</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Transfer modal behavior
        document.addEventListener('DOMContentLoaded', function(){
            const modal = document.getElementById('transfer-modal');
            const companyIdInput = document.getElementById('transfer-company-id');
            const companyNameEl = document.getElementById('transfer-company-name');
            const cancelBtn = document.getElementById('transfer-cancel');

            document.querySelectorAll('.transfer-btn').forEach(btn => {
                btn.addEventListener('click', function(){
                    const id = this.getAttribute('data-company-id');
                    const name = this.getAttribute('data-company-name') || '';
                    companyIdInput.value = id;
                    companyNameEl.textContent = name;
                    modal.style.display = 'flex';
                    document.getElementById('newOwnerFb').focus();
                });
            });

            cancelBtn.addEventListener('click', function(){ modal.style.display = 'none'; });

            // close modal on outside click
            modal.addEventListener('click', function(e){ if (e.target === modal) modal.style.display = 'none'; });
        });
    </script>

</body>
</html>