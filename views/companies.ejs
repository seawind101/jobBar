<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Companies</title>
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/companies.css">
    <script defer src="/js/searchJobs.js"></script>
</head>
<body>
    <%- include("banner.ejs") %>
    <section>
        <div id="sCont">
            <input type="text" id="searchbar" placeholder="Search...">
        </div>
        <div id="resourceCont">
            <%  if (companies && companies.length > 0) { %>
                <ul>
                    <% companies.forEach(company => { %>
                        <div class="company-item" style="--hover-color: <%= company.pColor %>">
                            <div class="nme">
                                <strong><%= company.name %></strong>
                                <% if (company.isOwner) { %>
                                    <div class="owned">Owner</div>
                                <% } %>
                            </div>
                            <div class="desc">
                                <p><%= company.description %></p>
                            </div>
                            <div class="btc">
                                <a id="v" href="/home/<%= encodeURIComponent(company.name) %>">
                                    <img src="/icons/home.png" width="15" height="15">
                                    <div class="text">Home</div></a>
                                <a id="v" href="<%= company.link %>" target="_blank" >
                                    <img src="/icons/redirect.png" width="15" height="15">
                                    <div class="text">Visit Site</div></a>
                                <a id="i" href="/Job/<%= encodeURIComponent(company.name) %>"> 
                                    <img src="/icons/issue.png" width="15" height="15">
                                    <div class="text">Issues</div></a>
                                <a id="p" href="/eJob/<%= encodeURIComponent(company.name) %>">
                                    <img src="/icons/position.png" width="15" height="15">
                                    <div class="text">Positions</div></a>
                            </div>
                            <% if (company.isOwner) { %>
                                    <a id="dlt">
                                        <form method="POST" action="/companies/delete" onsubmit="return confirm('Are you sure you want to delete this company? This cannot be undone.');">
                                            <input type="hidden" name="companyId" value="<%= company.id %>">
                                            <button type="submit" class="delete-company-btn">
                                                <img src="/icons/trash.png" width="20" height="20">
                                                <div class="text">Shut Down Company</div>
                                            </button>
                                        </form>
                                    </a>
                            <% } %>
                        </div>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>No companies yet.</p>
            <% } %>
        </div>
    </section>
</body>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.jobSearchInit) {
            window.jobSearchInit('searchbar', { selector: '.company-item' });
        }
        // Move owned companies to the top
        const container = document.querySelector("#resourceCont ul");
        if (container) {
            const companies = Array.from(container.querySelectorAll(".company-item"));
            companies.sort((a, b) => {
                const aOwner = a.querySelector(".owned") ? 1 : 0;
                const bOwner = b.querySelector(".owned") ? 1 : 0;
                return bOwner - aOwner; // owner first
            });
            companies.forEach(company => container.appendChild(company));
        }
    });
</script>
</html>