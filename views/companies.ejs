<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Companies</title>
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/companies.css">
    <script defer src="/js/searchJobs.js"></script>
</head>
<body>
    <%- include("banner.ejs") %>
    <section>
        <div id="sCont">
            <input type="text" id="searchbar" placeholder="Search...">
        </div>
        <div id="resourceCont">
            <%  if (companies && companies.length > 0) { %>
                <ul>
                    <% companies.forEach(company => { %>
                        <div class="company-item" style="background-color: <%= company.pColor %>; color: <%= company.bpColor %>; border: 2px solid <%= company.bpColor %>;">
                            <strong><%= company.name %></strong>
                            <p><%= company.description %></p>
                            <div class="btc">
                                <a id="v" href="<%= company.link %>" target="_blank" style="background-color: <%= company.sColor %>; color: <%= company.bsColor %>; border: 2px solid <%= company.bsColor %>;">
                                    <img src="/icons/redirect.png" width="15" height="15">
                                    <div class="text">Visit</div></a>
                                <a id="i" href="/Job/<%= encodeURIComponent(company.name) %>" class="btn-jobs" style="background-color: <%= company.sColor %>; color: <%= company.bsColor %>; border: 2px solid <%= company.bsColor %>;"> 
                                    <img src="/icons/issue.png" width="15" height="15">
                                    <div class="text">Issues</div></a>
                                <a id="p" href="/eJob/<%= encodeURIComponent(company.name) %>" class="btn-jobs" style="background-color: <%= company.sColor %>; color: <%= company.bsColor %>; border: 2px solid <%= company.bsColor %>;">
                                    <img src="/icons/position.png" width="15" height="15">
                                    <div class="text">Positions</div></a>
                                <% if (company.isOwner) { %>
                                    <a id="dlt">
                                        <form method="POST" action="/companies/delete" onsubmit="return confirm('Are you sure you want to delete this company? This cannot be undone.');">
                                            <input type="hidden" name="companyId" value="<%= company.id %>">
                                            <button type="submit" class="delete-company-btn">
                                                <img src="/icons/delete.png" width="15" height="15">
                                                <div class="text">Delete</div>
                                            </button>
                                        </form>
                                    </a>
                                <% } %>
                            </div>

                        </div>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>No companies yet.</p>
            <% } %>
        </div>
    </section>
</body>
        <script>
            document.addEventListener('DOMContentLoaded', function(){
                if (window.jobSearchInit) window.jobSearchInit('searchbar', { selector: '.company-item' });
            });
        </script>
</html>